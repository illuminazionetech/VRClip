<?xml version="1.0" encoding="utf-8"?>
<!-- VRClip brand mark (seal wearing a VR headset), inset ~9% on each side so its content -->
<!-- lands inside the adaptive-icon safe zone after OEM launchers mask it to their own shape. -->
<inset xmlns:android="http://schemas.android.com/apk/res/android"
    android:drawable="@drawable/vrclip_seal"
    android:insetLeft="9%"
    android:insetTop="9%"
    android:insetRight="9%"
    android:insetBottom="9%" />
